# Variables de entorno — NEXORA_CORE
# ====================================
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env real a Git.

# Token del bot de Telegram (obtenido desde @BotFather)
BOT_TOKEN=tu_token_de_telegram

# API Key de Groq (https://console.groq.com/keys)
GROQ_API_KEY=tu_api_key_de_groq

# Chat ID del administrador (tu ID personal de Telegram)
ADMIN_CHAT_ID=tu_chat_id
